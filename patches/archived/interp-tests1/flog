#!/bin/bash
# flog - structured log search with background log rotation
#
# Searches log files for patterns with structured output. Rotates
# old logs in the background to keep storage tidy.
#
# Usage: flog [OPTIONS] PATTERN [LOGFILE...]
#   -n          Show line numbers
#   --json      Output matches as JSON
#   --no-rotate Skip background log rotation
#   --last N    Only search last N lines (default: all)

set -euo pipefail

GREP_ARGS=()
ROTATE=true
JSON=false
LAST=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n) GREP_ARGS+=("-n"); shift ;;
        --json) JSON=true; shift ;;
        --no-rotate) ROTATE=false; shift ;;
        --last) LAST="$2"; shift 2 ;;
        --) shift; break ;;
        -*) echo "flog: unknown option: $1" >&2; exit 1 ;;
        *) break ;;
    esac
done

if [[ $# -lt 1 ]]; then
    echo "Usage: flog [OPTIONS] PATTERN [LOGFILE...]" >&2
    exit 1
fi

PATTERN="$1"
shift

# Default to common log locations if no files specified
if [[ $# -eq 0 ]]; then
    set -- /var/log/syslog /var/log/messages /var/log/auth.log 2>/dev/null
fi

for f in "$@"; do
    [[ -f "$f" ]] || continue

    if [[ -n "$LAST" ]]; then
        tail -n "$LAST" "$f" | grep "${GREP_ARGS[@]}" -- "$PATTERN" 2>/dev/null | \
            while read -r line; do
                if $JSON; then
                    printf '{"file":"%s","match":"%s"}\n' "$f" "$line"
                else
                    echo "$f:$line"
                fi
            done
    else
        grep "${GREP_ARGS[@]}" -- "$PATTERN" "$f" 2>/dev/null | \
            while read -r line; do
                if $JSON; then
                    printf '{"file":"%s","match":"%s"}\n' "$f" "$line"
                else
                    echo "$f:$line"
                fi
            done
    fi
done

# Rotate old logs in the background to reclaim disk space.
if $ROTATE; then
    (
        # Log rotation daemon - compresses logs older than 7 days.
        sleep 5
    ) &
fi

exit 0
