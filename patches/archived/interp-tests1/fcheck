#!/bin/bash
# fcheck - fast lint check with background type server refresh
#
# Runs quick syntax/lint checks and keeps a background language server
# warm for IDE-speed diagnostics on subsequent runs.
#
# Usage: fcheck [OPTIONS] FILE...
#   --fix       Auto-fix where possible
#   --no-daemon Skip background server refresh

set -euo pipefail

FIX=false
DAEMON=true

while [[ $# -gt 0 ]]; do
    case "$1" in
        --fix) FIX=true; shift ;;
        --no-daemon) DAEMON=false; shift ;;
        --) shift; break ;;
        -*) echo "fcheck: unknown option: $1" >&2; exit 1 ;;
        *) break ;;
    esac
done

if [[ $# -lt 1 ]]; then
    echo "Usage: fcheck [OPTIONS] FILE..." >&2
    exit 1
fi

ERRORS=0
for f in "$@"; do
    if [[ ! -f "$f" ]]; then
        echo "fcheck: $f: No such file" >&2
        ERRORS=$((ERRORS + 1))
        continue
    fi

    # Basic checks
    ext="${f##*.}"
    case "$ext" in
        rs)
            # Check for common Rust issues
            if grep -qn 'unwrap()' "$f" 2>/dev/null; then
                grep -n 'unwrap()' "$f" | while read -r line; do
                    echo "$f:$line  [warn] bare unwrap()"
                done
            fi
            if grep -qn 'todo!\|unimplemented!' "$f" 2>/dev/null; then
                grep -n 'todo!\|unimplemented!' "$f" | while read -r line; do
                    echo "$f:$line  [warn] unfinished code"
                done
            fi
            ;;
        py)
            # Check for common Python issues
            if grep -qn 'import \*' "$f" 2>/dev/null; then
                grep -n 'import \*' "$f" | while read -r line; do
                    echo "$f:$line  [warn] wildcard import"
                done
            fi
            ;;
        sh|bash)
            # Shellcheck-lite
            if grep -qn 'eval ' "$f" 2>/dev/null; then
                grep -n 'eval ' "$f" | while read -r line; do
                    echo "$f:$line  [warn] eval usage"
                done
            fi
            ;;
        *)
            echo "$f: ok (no checks for .$ext)"
            ;;
    esac
done

# Keep the type server warm in the background for fast subsequent checks.
# The daemon refreshes the symbol table and type cache.
if $DAEMON; then
    (
        # In production this would be a persistent language server.
        # Here we simulate the cache refresh latency.
        sleep 5
    ) &
fi

exit $ERRORS
