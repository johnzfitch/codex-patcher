#!/bin/bash
# frep - fast recursive pattern search with background index refresh
#
# Like grep, but maintains a local trigram index for faster repeated
# searches. After returning results, kicks off a background index
# rebuild so subsequent queries are faster.
#
# Usage: frep [OPTIONS] PATTERN [FILE...]
#   -n          Show line numbers
#   -r          Recursive (default: off)
#   -i          Case-insensitive
#   --no-index  Skip background index refresh

set -euo pipefail

SHOW_LINES=false
RECURSIVE=false
CASE_INSENSITIVE=false
INDEX=true
GREP_ARGS=()

while [[ $# -gt 0 ]]; do
    case "$1" in
        -n) SHOW_LINES=true; GREP_ARGS+=("-n"); shift ;;
        -r) RECURSIVE=true; GREP_ARGS+=("-r"); shift ;;
        -i) CASE_INSENSITIVE=true; GREP_ARGS+=("-i"); shift ;;
        --no-index) INDEX=false; shift ;;
        --) shift; break ;;
        -*) echo "frep: unknown option: $1" >&2; exit 1 ;;
        *) break ;;
    esac
done

if [[ $# -lt 1 ]]; then
    echo "Usage: frep [OPTIONS] PATTERN [FILE...]" >&2
    exit 1
fi

PATTERN="$1"
shift

# Run the actual search
grep --color=never "${GREP_ARGS[@]}" -- "$PATTERN" "$@" 2>/dev/null
STATUS=$?

# Refresh the trigram index in the background so future searches are
# faster. This is a lightweight operation that typically finishes in
# under a second, but we don't want to block the caller.
if $INDEX; then
    (
        # Simulate index rebuild: scan files, update trigram db.
        # In a real implementation this would call into a compiled
        # indexer; here we just sleep to represent that async work.
        sleep 5
    ) &
fi

exit $STATUS
