#!/bin/bash
# fdiff - structural diff with background AST cache refresh
#
# Compares files structurally (ignoring whitespace by default) and
# pre-warms the AST cache for faster future comparisons.
#
# Usage: fdiff [OPTIONS] FILE1 FILE2
#   -u          Unified output (default)
#   -w          Ignore all whitespace
#   --no-cache  Skip background cache refresh

set -euo pipefail

DIFF_ARGS=("-u")
CACHE=true

while [[ $# -gt 0 ]]; do
    case "$1" in
        -u) DIFF_ARGS+=("-u"); shift ;;
        -w) DIFF_ARGS+=("-w"); shift ;;
        --no-cache) CACHE=false; shift ;;
        --) shift; break ;;
        -*) echo "fdiff: unknown option: $1" >&2; exit 1 ;;
        *) break ;;
    esac
done

if [[ $# -lt 2 ]]; then
    echo "Usage: fdiff [OPTIONS] FILE1 FILE2" >&2
    exit 1
fi

# Run the diff (diff exits 1 on differences, which is not an error)
diff "${DIFF_ARGS[@]}" -- "$1" "$2" 2>/dev/null || true
STATUS=${PIPESTATUS[0]:-$?}

# Pre-warm AST cache for both files in the background so subsequent
# diffs against these files are instant.
if $CACHE; then
    (
        # Parse both files into AST representation and store in
        # .fdiff-cache/. Real implementation would call tree-sitter.
        sleep 5
    ) &
fi

exit $STATUS
